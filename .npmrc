# Several Sui SDKs (Suilend, Bucket, Scallop) declare conflicting exact-pin
# peerDependencies on @mysten/sui (2.3.1 vs >=2.0.0 vs ^2.11.0). Their actual
# runtime usage is API-stable across these versions, so we relax peer-dep
# resolution. Mirrors the local `npm install --legacy-peer-deps` we've been
# using during development.
legacy-peer-deps=true
